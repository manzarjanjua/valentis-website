# ---------------------------------------------------------------------------
# Valentis website environment variables
# Copy to ".env" and fill in. Vars prefixed PUBLIC_ are exposed to the client.
# ---------------------------------------------------------------------------

# Sanity (read) — used by the frontend at build time via GROQ.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-10-01

# Canonical site origin (no trailing slash). Used for canonical URLs, OG tags
# and the generated sitemap.
PUBLIC_SITE_URL=https://valentis.co.uk

# Sanity (write) — SERVER ONLY. Used by `npm run seed` to populate the
# siteSettings singleton. Create at https://sanity.io/manage (Editor token).
# Never commit a real value and never prefix it with PUBLIC_.
SANITY_WRITE_TOKEN=
