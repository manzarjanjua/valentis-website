# build output
dist/
studio/dist/

# dependencies
node_modules/

# Lockfile is intentionally NOT committed: it's generated on Windows and npm
# cannot reliably capture sharp's Linux/wasm optional deps, which breaks
# `npm ci` in CI. Omitting it makes Cloudflare run `npm install` instead.
package-lock.json

# generated by `astro sync`
.astro/

# copied at install time from @fontsource (see scripts/copy-fonts.mjs)
public/fonts/

# environment
.env
.env.production
.env.local

# editor / os
.DS_Store
.vscode/*
!.vscode/extensions.json
*.log
npm-debug.log*

# sanity
studio/.sanity/
