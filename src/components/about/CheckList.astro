---
/**
 * CheckList — a list of items each prefixed with a brand-orange check badge.
 * Reuses the home page's check-circle motif (see WhatYouGet). Set `onDark` on
 * ink sections so the item text stays legible.
 */
interface Props {
  items: string[];
  class?: string;
  onDark?: boolean;
}

const { items, class: className = '', onDark = false } = Astro.props;
---

<ul class:list={['grid gap-3.5', className]}>
  {
    items.map((item) => (
      <li class="flex items-start gap-3">
        <span
          class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-orange text-white"
          aria-hidden="true"
        >
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </span>
        <span class:list={[onDark ? 'text-white/85' : 'text-ink']}>{item}</span>
      </li>
    ))
  }
</ul>
