---
import Container from './primitives/Container.astro';
import Button from './primitives/Button.astro';
import type { SiteSettings } from '../lib/types';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const { nav, headerCta } = settings;
---

<header
  class="sticky top-0 z-50 border-b border-border bg-surface/85 backdrop-blur supports-[backdrop-filter]:bg-surface/75"
>
  <Container class="flex h-16 items-center justify-between gap-4 md:h-[4.5rem]">
    <a href="/" aria-label="Valentis — home" class="inline-flex items-center">
      <img src="/logo.svg" alt="Valentis" width="263" height="32" class="h-5 w-auto md:h-6" />
    </a>

    <!-- Desktop navigation -->
    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-8">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="font-heading text-[0.95rem] font-medium text-ink/80 transition-colors hover:text-ink"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="hidden md:block">
      <Button
        variant="primary"
        data-booking-toggle
        aria-controls="booking-panel"
        aria-expanded="false"
      >
        {headerCta.label}
      </Button>
    </div>

    <!-- Mobile menu toggle -->
    <button
      type="button"
      id="nav-toggle"
      class="inline-flex items-center justify-center rounded-md p-2 text-ink md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
        data-icon="open"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg
        class="hidden h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
        data-icon="close"
      >
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>
  </Container>

  <!-- Mobile navigation panel -->
  <div id="mobile-nav" class="md:hidden" hidden>
    <nav aria-label="Primary mobile" class="border-t border-border bg-surface">
      <Container class="py-4">
        <ul class="flex flex-col">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="block border-b border-border/70 py-3 font-heading text-base font-medium text-ink"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="pt-4">
          <Button
            variant="primary"
            class="w-full"
            data-booking-toggle
            aria-controls="booking-panel"
            aria-expanded="false"
          >
            {headerCta.label}
          </Button>
        </div>
      </Container>
    </nav>
  </div>

  <!-- Booking panel: drops down under the header with a white background -->
  <div
    id="booking-panel"
    class="absolute inset-x-0 top-full max-h-[85vh] overflow-y-auto border-t border-border bg-surface shadow-card"
    hidden
  >
    <Container class="py-5">
      <div class="mb-3 flex items-center justify-between gap-4">
        <p class="font-heading text-h4 font-semibold text-ink">{headerCta.label}</p>
        <button
          type="button"
          data-booking-close
          aria-label="Close booking"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md text-ink transition-colors hover:bg-surface-2"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>
      </div>
      <iframe
        data-src="https://api.leadconnectorhq.com/widget/booking/iHPqdqux8uoEmCUeAGjL"
        style="width:100%;min-height:680px;border:none;overflow:hidden"
        scrolling="no"
        id="iHPqdqux8uoEmCUeAGjL_1775728666886"
        title="Book a Discovery Call"></iframe>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const openIcon = toggle?.querySelector('[data-icon="open"]');
  const closeIcon = toggle?.querySelector('[data-icon="close"]');

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    panel.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  }

  toggle?.addEventListener('click', () => {
    setOpen(panel?.hidden ?? false);
  });

  // Close mobile nav on navigation (anchor click).
  panel?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });

  // Booking panel (opened by the "Book a Discovery Call" buttons).
  const bookingPanel = document.getElementById('booking-panel');
  const bookingToggles = document.querySelectorAll<HTMLElement>('[data-booking-toggle]');
  const bookingClose = bookingPanel?.querySelector<HTMLElement>('[data-booking-close]');

  const bookingFrame = document.getElementById(
    'iHPqdqux8uoEmCUeAGjL_1775728666886'
  ) as HTMLIFrameElement | null;

  function setBooking(open: boolean) {
    if (!bookingPanel) return;
    bookingPanel.hidden = !open;
    bookingToggles.forEach((t) => t.setAttribute('aria-expanded', String(open)));
    if (open) {
      setOpen(false); // close the mobile nav if it was open
      // Load the calendar only once the panel is visible so it never
      // initialises inside a display:none container (renders blank otherwise).
      if (bookingFrame && !bookingFrame.src && bookingFrame.dataset.src) {
        bookingFrame.src = bookingFrame.dataset.src;
      }
    }
  }

  bookingToggles.forEach((t) => {
    t.addEventListener('click', () => setBooking(bookingPanel?.hidden ?? false));
  });
  bookingClose?.addEventListener('click', () => setBooking(false));

  // Click outside the booking panel closes it.
  document.addEventListener('click', (e) => {
    if (!bookingPanel || bookingPanel.hidden) return;
    const t = e.target as HTMLElement;
    if (!t.closest('#booking-panel') && !t.closest('[data-booking-toggle]')) setBooking(false);
  });

  // Escape closes whichever panel is open.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (panel && !panel.hidden) {
      setOpen(false);
      (toggle as HTMLButtonElement | null)?.focus();
    }
    if (bookingPanel && !bookingPanel.hidden) setBooking(false);
  });

  // Reset panels when crossing into the desktop breakpoint.
  const mq = window.matchMedia('(min-width: 768px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>
