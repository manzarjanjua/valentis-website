---
import Container from './primitives/Container.astro';
import type { SiteSettings } from '../lib/types';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const { tagline, social, quickLinks, phone, email, address, copyright } = settings;

// Inline SVG paths keyed by platform (lightweight, no icon font).
const ICONS: Record<string, string> = {
  LinkedIn:
    'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-.95 1.82-1.95 3.75-1.95C20.4 8.75 22 10.6 22 14.1V21h-4v-6.1c0-1.45-.03-3.3-2-3.3-2 0-2.3 1.57-2.3 3.2V21H9V9Z',
  X: 'M17.53 3H20.5l-6.5 7.43L21.75 21H15.8l-4.67-6.1L5.8 21H2.83l6.96-7.95L2.5 3h6.1l4.22 5.58L17.53 3Zm-1.04 16h1.64L7.6 4.74H5.84L16.49 19Z',
  Facebook:
    'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.9h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z',
  Instagram:
    'M12 2c2.72 0 3.06.01 4.12.06 1.07.05 1.8.22 2.43.47.66.25 1.22.6 1.77 1.15.55.55.9 1.11 1.15 1.77.25.63.42 1.36.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.07-.22 1.8-.47 2.43-.25.66-.6 1.22-1.15 1.77-.55.55-1.11.9-1.77 1.15-.63.25-1.36.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.07-.05-1.8-.22-2.43-.47a4.9 4.9 0 0 1-1.77-1.15 4.9 4.9 0 0 1-1.15-1.77c-.25-.63-.42-1.36-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.07.22-1.8.47-2.43.25-.66.6-1.22 1.15-1.77.55-.55 1.11-.9 1.77-1.15.63-.25 1.36-.42 2.43-.47C8.94 2.01 9.28 2 12 2Zm0 1.8c-2.67 0-2.99.01-4.04.06-.98.04-1.5.21-1.86.35-.47.18-.8.4-1.15.75-.35.35-.57.68-.75 1.15-.14.36-.31.88-.35 1.86-.05 1.05-.06 1.37-.06 4.04s.01 2.99.06 4.04c.04.98.21 1.5.35 1.86.18.47.4.8.75 1.15.35.35.68.57 1.15.75.36.14.88.31 1.86.35 1.05.05 1.37.06 4.04.06s2.99-.01 4.04-.06c.98-.04 1.5-.21 1.86-.35.47-.18.8-.4 1.15-.75.35-.35.57-.68.75-1.15.14-.36.31-.88.35-1.86.05-1.05.06-1.37.06-4.04s-.01-2.99-.06-4.04c-.04-.98-.21-1.5-.35-1.86a3.1 3.1 0 0 0-.75-1.15 3.1 3.1 0 0 0-1.15-.75c-.36-.14-.88-.31-1.86-.35-1.05-.05-1.37-.06-4.04-.06Zm0 3.06a5.14 5.14 0 1 1 0 10.28 5.14 5.14 0 0 1 0-10.28Zm0 1.8a3.34 3.34 0 1 0 0 6.68 3.34 3.34 0 0 0 0-6.68Zm5.34-3.21a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z',
};

const fullAddress = [address.street, address.city, address.country, address.postalCode]
  .filter(Boolean)
  .join(', ');
---

<footer class="border-t border-white/15 bg-ink-2 text-white">
  <Container class="py-section-sm">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr] lg:gap-16">
      <!-- Brand + social -->
      <div>
        <a href="/" aria-label="Valentis — home" class="inline-block">
          <img src="/logo-w.svg" alt="Valentis" width="263" height="32" class="h-6 w-auto" />
        </a>
        <p class="mt-4 max-w-xs text-small text-white/70">{tagline}</p>

        <ul class="mt-6 flex items-center gap-3">
          {
            social.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="inline-flex h-10 w-10 items-center justify-center rounded-full ring-1 ring-inset ring-white/20 text-white/80 transition-colors hover:bg-white/10 hover:text-white"
                  aria-label={s.platform}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={ICONS[s.platform] ?? ''} />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Quick links -->
      <nav aria-label="Quick links">
        <h2 class="font-heading text-eyebrow font-semibold uppercase tracking-[0.14em] text-white/50">
          Quick Links
        </h2>
        <ul class="mt-4 grid grid-cols-2 gap-x-8 gap-y-3">
          {
            quickLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-small text-white/80 transition-colors hover:text-brand-orange"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h2 class="font-heading text-eyebrow font-semibold uppercase tracking-[0.14em] text-white/50">
          Contact
        </h2>
        <address class="mt-4 space-y-3 not-italic text-small text-white/80">
          <div>
            <a href={`mailto:${email}`} class="transition-colors hover:text-brand-orange">{email}</a>
          </div>
          <div>
            <a
              href={`tel:${phone.replace(/\s+/g, '')}`}
              class="transition-colors hover:text-brand-orange">{phone}</a
            >
          </div>
          <div class="max-w-xs text-white/70">{fullAddress}</div>
        </address>
      </div>
    </div>

    <div
      class="mt-12 border-t border-white/10 pt-6 text-small text-white/55"
    >
      {copyright}
    </div>
  </Container>
</footer>
