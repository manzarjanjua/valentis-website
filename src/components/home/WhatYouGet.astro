---
import Section from '../primitives/Section.astro';
import type { WhatYouGetContent } from '../../lib/types';

interface Props {
  content: WhatYouGetContent;
}

const { content } = Astro.props;
const { title, subtitle, items } = content;
---

<Section id="what-you-get" variant="surface" ariaLabelledby="wyg-title">
  <header class="max-w-2xl">
    <h2 id="wyg-title" class="text-h2 font-bold">
      {title}
      <span class="block text-brand-orange">{subtitle}</span>
    </h2>
  </header>

  <ul class="mt-10 grid gap-x-10 gap-y-5 sm:grid-cols-2">
    {
      items.map((item) => (
        <li class="flex items-start gap-4 rounded-md border border-border bg-surface-2 p-4">
          <span
            class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-orange text-white"
            aria-hidden="true"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span class="text-ink">{item}</span>
        </li>
      ))
    }
  </ul>
</Section>
