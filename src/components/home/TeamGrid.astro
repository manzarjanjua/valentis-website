---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Section from '../primitives/Section.astro';
import Eyebrow from '../primitives/Eyebrow.astro';
import type { TeamContent } from '../../lib/types';

interface Props {
  content: TeamContent;
}

const { content } = Astro.props;
const { eyebrow, title, members } = content;

// Build-time optimized team photos (src/assets/team/*.png).
const teamImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/team/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

function resolvePhoto(photo?: string): ImageMetadata | undefined {
  if (!photo) return undefined;
  const match = Object.entries(teamImages).find(([path]) => path.endsWith(`/${photo}`));
  return match?.[1].default;
}

const initials = (name: string) =>
  name
    .split(/\s+/)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? '')
    .join('');
---

<Section id="team" variant="surface-2" ariaLabelledby="team-title">
  <header class="max-w-2xl">
    <Eyebrow>{eyebrow}</Eyebrow>
    <h2 id="team-title" class="mt-4 text-h2 font-bold">{title}</h2>
  </header>

  <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      members.map((member) => {
        const img = resolvePhoto(member.photo);
        return (
          <li class="flex flex-col overflow-hidden rounded-lg border border-border bg-surface text-center shadow-soft">
            {img ? (
              <Picture
                src={img}
                formats={['avif', 'webp']}
                fallbackFormat="png"
                widths={[380, 560, 760]}
                sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
                alt={`${member.name}, ${member.role}`}
                loading="lazy"
                decoding="async"
                class="aspect-[501/334] w-full bg-surface-2 object-cover"
              />
            ) : (
              <div class="flex aspect-[501/334] w-full items-center justify-center bg-ink-2">
                <span class="font-heading text-h2 font-semibold text-white" aria-hidden="true">
                  {initials(member.name)}
                </span>
              </div>
            )}

            <div class="p-6">
              <h3 class="text-h4 font-semibold">{member.name}</h3>
              <p class="mt-1 text-muted">{member.role}</p>
            </div>
          </li>
        );
      })
    }
  </ul>
</Section>
