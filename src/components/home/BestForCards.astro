---
import Section from '../primitives/Section.astro';
import Button from '../primitives/Button.astro';
import type { BestForContent } from '../../lib/types';

interface Props {
  content: BestForContent;
}

const { content } = Astro.props;
const { title, items, midCtaBand } = content;

// Decorative inline icons, one per card.
const ICONS = [
  'M3 12a9 9 0 1 1 18 0 9 9 0 0 1-18 0Zm9-4v4l2.5 2.5', // clarity (clock/target-ish)
  'M3 17l6-6 4 4 8-8M21 7v6M21 7h-6', // scaling (trend up)
  'M12 3l8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Z', // shield (CFO-level)
];
---

<Section id="why-us" variant="surface-2" ariaLabelledby="bestfor-title">
  <header class="max-w-2xl">
    <h2 id="bestfor-title" class="text-h2 font-bold">{title}</h2>
  </header>

  <div class="mt-10 grid gap-6 md:grid-cols-3">
    {
      items.map((item, i) => (
        <article class="group flex h-full flex-col rounded-lg border border-border bg-surface p-7 shadow-soft transition duration-200 ease-[var(--ease-out-soft)] motion-safe:hover:-translate-y-1 hover:shadow-card">
          <span
            class="flex h-12 w-12 items-center justify-center rounded-md bg-brand-orange-soft text-brand-orange"
            aria-hidden="true"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={ICONS[i % ICONS.length]} />
            </svg>
          </span>
          <h3 class="mt-5 text-h4 font-semibold">{item.title}</h3>
          <p class="mt-3 text-muted">{item.description}</p>
        </article>
      ))
    }
  </div>

  {/* Mid-page CTA band (CLAUDE.md §3.5) */}
  <div class="mt-12 flex flex-col items-start gap-6 rounded-xl border border-border bg-brand-orange-soft p-8 md:flex-row md:items-center md:justify-between md:p-10">
    <div class="max-w-2xl">
      <h3 class="text-h3 font-semibold text-ink">{midCtaBand.heading}</h3>
      <p class="mt-2 text-muted">{midCtaBand.body}</p>
    </div>
    <Button href={midCtaBand.cta.href} variant="primary" size="lg" class="shrink-0">
      {midCtaBand.cta.label}
    </Button>
  </div>
</Section>
