---
import Section from '../primitives/Section.astro';
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';
import type { ServiceCategory, ServicesContent } from '../../lib/types';

interface Props {
  content: ServicesContent;
}

const { content } = Astro.props;
const { eyebrow, title, intro, categories, helperText, subCta } = content;

// Pick a panel layout from the shape of the data (no per-item config needed):
//  - "columns": groups have headings → titled columns of bullet lists
//  - "cards":   items carry descriptions → titled cards
//  - "chips":   plain labels → dot chips
type Mode = 'columns' | 'cards' | 'chips';
const modeFor = (cat: ServiceCategory): Mode => {
  if (cat.groups.some((g) => g.heading)) return 'columns';
  if (cat.groups.some((g) => g.items.some((i) => i.description))) return 'cards';
  return 'chips';
};
const flatItems = (cat: ServiceCategory) => cat.groups.flatMap((g) => g.items);

const arrowPath = 'M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3';
---

<Section id="services" variant="surface" ariaLabelledby="services-title">
  <header class="max-w-2xl">
    <Eyebrow>{eyebrow}</Eyebrow>
    <h2 id="services-title" class="mt-4 text-h2 font-bold">{title}</h2>
    <p class="mt-4 text-lead text-muted">{intro}</p>
  </header>

  <div class="mt-12" data-services>
    {/* Tiles */}
    <ul class="grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-5 lg:gap-4">
      {
        categories.map((cat, i) => (
          <li class="h-full">
            <button
              type="button"
              class:list={[
                'service-tile group flex h-full w-full flex-col items-center gap-4 rounded-xl border border-border bg-surface p-6 text-center transition duration-200 ease-[var(--ease-out-soft)] hover:border-transparent hover:shadow-card motion-safe:hover:-translate-y-1',
                i === 0 && 'is-active',
              ]}
              data-service={i}
              aria-controls={`service-panel-${i}`}
              aria-expanded={i === 0 ? 'true' : 'false'}
            >
              <span class="tile-icon flex h-12 w-12 items-center justify-center rounded-lg bg-brand-orange-soft text-brand-orange transition-colors">
                <svg
                  class="h-6 w-6"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={cat.icon} />
                </svg>
              </span>
              <span class="tile-text font-heading text-small font-medium leading-snug text-ink">
                {cat.title}
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    {/* Details panel */}
    <div
      class="mt-6 rounded-xl border border-border bg-surface p-6 shadow-soft md:p-8"
      style="min-height: 320px"
    >
      {/* Default prompt — hidden by default since the first service is shown
          on load; revealed only if no tile is active. */}
      <div
        class="flex h-full min-h-[256px] items-center justify-center"
        data-service-default
        hidden
      >
        <p class="text-muted">{helperText}</p>
      </div>

      {/* One panel per service; the first is shown by default. */}
      {
        categories.map((cat, i) => {
          const mode = modeFor(cat);
          const items = flatItems(cat);
          return (
            <div
              id={`service-panel-${i}`}
              class="service-panel"
              hidden={i !== 0}
              data-service-panel
            >
              <h3 class="text-h3 font-semibold">{cat.title}</h3>
              <p class="mt-2 text-muted">{cat.tagline}</p>

              {mode === 'chips' && (
                <ul class="mt-6 grid gap-3 sm:grid-cols-2">
                  {items.map((it) => (
                    <li class="flex items-center gap-3 rounded-md bg-surface-2 p-4">
                      <span class="h-2 w-2 shrink-0 rounded-full bg-brand-orange" aria-hidden="true" />
                      <span class="text-ink">{it.label}</span>
                    </li>
                  ))}
                </ul>
              )}

              {mode === 'cards' && (
                <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {items.map((it) => (
                    <div class="rounded-md bg-surface-2 p-5">
                      <h4 class="font-heading font-semibold text-ink">{it.label}</h4>
                      {it.description && <p class="mt-1.5 text-small text-muted">{it.description}</p>}
                    </div>
                  ))}
                </div>
              )}

              {mode === 'columns' && (
                <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                  {cat.groups.map((group) => (
                    <div>
                      {group.heading && (
                        <h4 class="font-heading font-semibold text-ink">{group.heading}</h4>
                      )}
                      <ul class="mt-3 space-y-2">
                        {group.items.map((it) => (
                          <li class="flex items-start gap-2.5 text-small text-muted">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-orange" aria-hidden="true" />
                            <span>{it.label}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              )}

              <a
                href={cat.learnMore.href}
                class="mt-7 inline-flex items-center gap-2 font-heading text-small font-medium text-brand-orange transition-colors hover:text-[#d94e22]"
              >
                {cat.learnMore.label}
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={arrowPath} />
                </svg>
              </a>
            </div>
          );
        })
      }
    </div>

    {/* Sub-CTA (CLAUDE.md §3.6) */}
    <div class="mt-12 flex flex-col items-center gap-4 text-center">
      <p class="text-muted">{subCta.text}</p>
      <Button href={subCta.cta.href} variant="secondary" size="lg">
        {subCta.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </Button>
    </div>
  </div>
</Section>

<style>
  /* Active tile: brand-orange fill with inverted icon/text. */
  .service-tile.is-active {
    background-color: var(--color-brand-orange);
    border-color: transparent;
    box-shadow: var(--shadow-card);
    transform: translateY(-4px);
  }
  .service-tile.is-active .tile-text {
    color: #fff;
  }
  .service-tile.is-active .tile-icon {
    background-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }
  .service-panel {
    animation: service-fade 0.3s var(--ease-out-soft);
  }
  @keyframes service-fade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .service-panel {
      animation: none;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-services]');
  if (root) {
    const tiles = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-service]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-service-panel]'));
    const fallback = root.querySelector<HTMLElement>('[data-service-default]');
    const canHover = window.matchMedia('(hover: hover)').matches;

    function show(index: number | null) {
      panels.forEach((panel, i) => (panel.hidden = i !== index));
      tiles.forEach((tile, i) => {
        const active = i === index;
        tile.classList.toggle('is-active', active);
        tile.setAttribute('aria-expanded', String(active));
      });
      if (fallback) fallback.hidden = index !== null;
    }

    tiles.forEach((tile, i) => {
      // Hover preview (pointer devices), keyboard focus, and click/tap all reveal.
      if (canHover) tile.addEventListener('pointerenter', () => show(i));
      tile.addEventListener('focus', () => show(i));
      tile.addEventListener('click', () => show(i));
    });
  }
</script>
