---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Eyebrow from '../primitives/Eyebrow.astro';
import type { Story } from '../../lib/types';

/**
 * StoryCard — one client story as a grid card with a horizontal split: a
 * full-height framed logo panel on the left, and the editorial content
 * (title, testimonial/result, attribution, link) on the right. Stacks on
 * mobile. The "Read the story" link is stretched over the whole card.
 */
interface Props {
  story: Story;
  image?: ImageMetadata;
  index: number;
}

const { story, image, index } = Astro.props;
const { label, name, company, industry, logoAlt, quote, result, href } = story;

const headingId = `story-title-${index}`;
const companyName = company.split('–')[0].trim();
---

<article
  class="group relative flex h-full flex-col-reverse overflow-hidden rounded-2xl border border-border bg-surface shadow-soft transition duration-200 ease-[var(--ease-out-soft)] hover:shadow-card motion-safe:hover:-translate-y-1 sm:flex-row-reverse"
  aria-labelledby={headingId}
>
  {/* Body */}
  <div class="flex flex-1 flex-col p-7 md:p-8">
    <Eyebrow>{industry}</Eyebrow>
    <h2 id={headingId} class="mt-3 text-h4 font-semibold">{label}</h2>

    {
      quote ? (
        <div class="mt-5 flex-1">
          <blockquote class="border-l-2 border-brand-orange pl-5">
            <p class="text-ink">{quote}</p>
          </blockquote>
        </div>
      ) : result ? (
        <div class="mt-5 flex-1">
          <div class="inline-flex flex-col rounded-xl border border-brand-orange/30 bg-brand-orange-soft px-5 py-4">
            <span class="font-heading text-h3 font-bold leading-none text-brand-orange">
              {result.value}
            </span>
            <span class="mt-2 text-small font-medium text-ink">{result.label}</span>
          </div>
        </div>
      ) : (
        <div class="flex-1" />
      )
    }

    <div class="mt-6 border-t border-border pt-5">
      <p class="text-small text-muted">
        <span class="font-medium text-ink">{name}</span> · {company}
      </p>
      <a
        href={href}
        class="mt-4 inline-flex items-center gap-2 font-heading text-[0.95rem] font-semibold text-brand-orange after:absolute after:inset-0 after:content-['']"
        aria-label={`Read the story: ${label}`}
      >
        Read the story
        <svg
          class="h-4 w-4 transition-transform duration-200 ease-[var(--ease-out-soft)] group-hover:translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>

  {/* Logo panel (left on desktop, above on mobile). The whole logo is shown,
      centered and uncropped. */}
  <div
    class="flex min-h-[12rem] items-center justify-center border-b border-border bg-white p-6 md:p-8 sm:min-h-0 sm:w-2/5 sm:shrink-0 sm:self-stretch sm:border-b-0 sm:border-r"
  >
    {
      image ? (
        <Image
          src={image}
          alt={`${logoAlt} logo`}
          widths={[300, 400]}
          sizes="(min-width: 640px) 18rem, 70vw"
          loading="lazy"
          decoding="async"
          class="max-h-60 w-auto max-w-full object-contain sm:max-h-full"
        />
      ) : (
        <span class="font-heading text-h3 font-bold text-ink/30">{logoAlt}</span>
      )
    }
  </div>
</article>
