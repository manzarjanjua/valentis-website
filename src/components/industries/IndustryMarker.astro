---
import type { IndustryBulletTone } from '../../lib/types';

/**
 * IndustryMarker — the leading marker for a bullet item. A positive check
 * (default), a neutral dot, or an amber "problem" mark for challenge lists.
 * Adapts to dark sections via `onDark`.
 */
interface Props {
  tone?: IndustryBulletTone;
  /** Render at the smaller size used inside cards. */
  small?: boolean;
  /** Tune colours for a dark (navy) background. */
  onDark?: boolean;
}

const { tone = 'check', small = false, onDark = false } = Astro.props;
const box = small ? 'h-5 w-5' : 'h-6 w-6';
const icon = small ? 'h-3 w-3' : 'h-3.5 w-3.5';
---

{
  tone === 'check' && (
    <span
      class:list={[
        'mt-0.5 flex shrink-0 items-center justify-center rounded-full',
        box,
        onDark ? 'bg-brand-orange text-white' : 'bg-brand-orange-soft text-brand-orange',
      ]}
      aria-hidden="true"
    >
      <svg class={icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </span>
  )
}

{
  tone === 'problem' && (
    <span
      class:list={[
        'mt-0.5 flex shrink-0 items-center justify-center rounded-full',
        box,
        onDark ? 'bg-brand-orange/20 text-brand-orange' : 'bg-brand-orange/10 text-brand-orange',
      ]}
      aria-hidden="true"
    >
      <svg class={icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9" />
        <line x1="12" y1="8" x2="12" y2="13" />
        <line x1="12" y1="16.5" x2="12" y2="16.5" />
      </svg>
    </span>
  )
}

{
  tone === 'dot' && (
    <span
      class:list={[
        'mt-0.5 flex shrink-0 items-center justify-center rounded-full border',
        box,
        onDark ? 'border-white/20' : 'border-border',
      ]}
      aria-hidden="true"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-brand-orange" />
    </span>
  )
}
