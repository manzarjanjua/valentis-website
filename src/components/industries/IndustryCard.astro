---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Industry } from '../../lib/types';

/**
 * IndustryCard — one sector as a vertical card: a fixed-ratio cover image with
 * the sector name set over a gradient scrim, then the description and a
 * "Learn more" link. The whole card is clickable (stretched link). Image
 * dimensions are reserved via the aspect-ratio box to keep CLS at zero.
 */
interface Props {
  industry: Industry;
  image?: ImageMetadata;
  index: number;
}

const { industry, image, index } = Astro.props;
const { name, description, imageAlt, href } = industry;

const headingId = `industry-title-${index}`;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-surface shadow-soft transition duration-200 ease-[var(--ease-out-soft)] hover:shadow-card motion-safe:hover:-translate-y-1"
  aria-labelledby={headingId}
>
  {/* Cover image + title overlay */}
  <div class="relative aspect-[16/10] overflow-hidden bg-surface-2">
    {
      image ? (
        <Image
          src={image}
          alt={imageAlt}
          widths={[400, 600, 800]}
          sizes="(min-width: 1024px) 26rem, (min-width: 640px) 45vw, 90vw"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-out-soft)] motion-safe:group-hover:scale-[1.04]"
        />
      ) : (
        <div class="h-full w-full bg-ink-2" />
      )
    }

    <div
      class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/25 to-transparent"
      aria-hidden="true"
    >
    </div>

    <h2
      id={headingId}
      class="absolute inset-x-0 bottom-0 p-6 text-h4 font-semibold text-white"
    >
      {name}
    </h2>
  </div>

  {/* Body */}
  <div class="flex flex-1 flex-col p-6 md:p-7">
    <p class="flex-1 text-muted">{description}</p>

    <span
      class="mt-6 inline-flex items-center gap-2 font-heading text-[0.95rem] font-semibold text-brand-orange"
    >
      Learn more
      <svg
        class="h-4 w-4 transition-transform duration-200 ease-[var(--ease-out-soft)] group-hover:translate-x-1"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>

  {/* Stretched link covers the whole card for an accessible, single hit-area. */}
  <a href={href} class="absolute inset-0" aria-label={`Learn more about ${name}`}>
    <span class="sr-only">{`Learn more about ${name}`}</span>
  </a>
</article>
