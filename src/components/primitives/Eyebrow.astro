---
/**
 * Eyebrow — small uppercase label above a section heading. Brand-orange with
 * a short leading rule for the engineered, premium feel.
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  /** Set false on dark (ink) sections to keep contrast crisp. */
  rule?: boolean;
}

const { as: Tag = 'p', class: className = '', rule = true } = Astro.props;
---

<Tag
  class:list={[
    'inline-flex items-center gap-3 font-heading text-eyebrow font-semibold uppercase text-brand-orange',
    className,
  ]}
>
  {rule && <span aria-hidden="true" class="h-px w-8 bg-brand-orange/70"></span>}
  <slot />
</Tag>
