---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/home/ContactSection.astro';
import { getSiteSettings } from '../lib/content';
import type { ContactContent } from '../lib/types';
import {
  DEFAULT_TITLE,
  DEFAULT_DESCRIPTION,
  DEFAULT_OG_IMAGE,
  SITE_NAME,
  buildJsonLd,
} from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL of the social share image. */
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Set true on pages that should not be indexed. */
  noindex?: boolean;
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  noindex = false,
} = Astro.props;

const settings = await getSiteSettings();

// The global pre-footer contact block. Heading copy comes from settings.contact;
// phone/email/location are composed from settings so there's one source of truth.
const contactContent: ContactContent = {
  ...settings.contact,
  phone: settings.phone,
  email: settings.email,
  location: [settings.address.street, settings.address.city, settings.address.postalCode]
    .filter(Boolean)
    .join(', '),
};

// Astro.site is set in astro.config.mjs. Fall back defensively for dev.
const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';
const canonical = new URL(Astro.url.pathname, siteOrigin).href;
const ogImageUrl = new URL(ogImage, siteOrigin).href;
const logoUrl = new URL('/logo.svg', siteOrigin).href;

const jsonLd = buildJsonLd(settings, siteOrigin, logoUrl);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to the Sanity CDN for any runtime image requests -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />

    <!-- Preload the two most-used self-hosted font weights for fast, stable LCP -->
    <link
      rel="preload"
      href="/fonts/montserrat-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/poppins-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'}
    />
    <meta name="theme-color" content="#011013" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="mask-icon" href="/favicon.svg" color="#F15A29" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data: Organization + AccountingService/LocalBusiness -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Page-specific <head> additions (extra JSON-LD, meta, preloads). */}
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-ink-2 focus:px-4 focus:py-2 focus:text-white"
      >Skip to content</a
    >

    <Header settings={settings} />

    <main id="main" class="flex-1">
      <slot />
    </main>

    {/* Global pre-footer contact block ("Need a Smarter Finance Setup?").
        Rendered on every page; #contact anchors site-wide resolve here. */}
    <ContactSection content={contactContent} />

    <Footer settings={settings} />

    {/* LeadConnector embed script — resizes the booking (header) and enquiry
        (contact) iframes. Deferred so it never blocks render. */}
    <script is:inline defer src="https://link.msgsndr.com/js/form_embed.js"></script>
  </body>
</html>
