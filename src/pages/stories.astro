---
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/primitives/Section.astro';
import Button from '../components/primitives/Button.astro';
import CtaBand from '../components/home/CtaBand.astro';
import StoryCard from '../components/stories/StoryCard.astro';
import { storiesContent as s } from '../lib/storiesContent';

const { hero, stories, finalCta } = s;

// Build-time optimized client logos (src/assets/stories/*). Matched by base
// filename so the source extension (.png/.webp) doesn't matter.
const logos = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/stories/*.{png,jpg,jpeg,webp,svg}',
  { eager: true }
);

function resolveLogo(base: string): ImageMetadata | undefined {
  const match = Object.entries(logos).find(([path]) => {
    const file = path.split('/').pop() ?? '';
    return file.replace(/\.[^.]+$/, '') === base;
  });
  return match?.[1].default;
}

// Breadcrumb JSON-LD (CLAUDE.md §6).
const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Stories', item: `${siteOrigin}/stories` },
  ],
};
---

<BaseLayout title={s.seo.title} description={s.seo.description}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />

  <PageHero
    eyebrow={hero.eyebrow}
    heading={hero.heading}
    subheading={hero.subheading}
    breadcrumbLabel="Stories"
    headingId="stories-hero-heading"
  >
    <Button href={hero.primaryCta.href} variant="primary" size="lg">
      {hero.primaryCta.label}
    </Button>
  </PageHero>

  {/* 2×2 grid of case-study cards. */}
  <Section variant="surface" ariaLabel="Client stories">
    <div class="grid gap-6 md:gap-8 lg:grid-cols-2">
      {
        stories.map((story, i) => (
          <StoryCard story={story} image={resolveLogo(story.logo)} index={i} />
        ))
      }
    </div>
  </Section>

  <CtaBand content={finalCta} id="stories-cta" />
</BaseLayout>
