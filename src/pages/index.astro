---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ProcessTimeline from '../components/home/ProcessTimeline.astro';
import WhatYouGet from '../components/home/WhatYouGet.astro';
import BestForCards from '../components/home/BestForCards.astro';
import ServicesTiles from '../components/home/ServicesTiles.astro';
import TeamGrid from '../components/home/TeamGrid.astro';
import CtaBand from '../components/home/CtaBand.astro';
import { homeContent } from '../lib/homeContent';

const c = homeContent;
---

<BaseLayout>
  {/* 3.2  Hero — "How We Work" (LCP, <h1>) */}
  <Hero content={c.hero} />

  {/* 3.3  Our Process — "The Valentis Method" */}
  <ProcessTimeline content={c.process} />

  {/* 3.4  What You Get — "(In Plain English)" */}
  <WhatYouGet content={c.whatYouGet} />

  {/* 3.5  "This Works Best For Businesses That…" (incl. mid-page CTA band) */}
  <BestForCards content={c.bestFor} />

  {/* 3.6  Our Services — "How Can We Help You?" */}
  <ServicesTiles content={c.services} />

  {/* 3.7  Our Team — "Meet the Team" */}
  <TeamGrid content={c.team} />

  {/* 3.9  Final CTA Band — "Ready to Stop Guessing With Your Finances?"
      3.8 Contact ("Need a Smarter Finance Setup?") is now a global pre-footer
      block rendered by BaseLayout, so it appears on every page. */}
  <CtaBand content={c.finalCta} id="final-cta" />
</BaseLayout>
