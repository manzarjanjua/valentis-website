---
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/primitives/Section.astro';
import Button from '../components/primitives/Button.astro';
import CtaBand from '../components/home/CtaBand.astro';
import IndustryCard from '../components/industries/IndustryCard.astro';
import { industriesContent as ind } from '../lib/industriesContent';

const { hero, industries, why, fallbackCta } = ind;

// Build-time optimized sector images (src/assets/industries/*). Matched by base
// filename so the source extension doesn't matter.
const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/industries/*.{png,jpg,jpeg,webp,avif,svg}',
  { eager: true }
);

function resolveImage(base: string): ImageMetadata | undefined {
  const match = Object.entries(images).find(([path]) => {
    const file = path.split('/').pop() ?? '';
    return file.replace(/\.[^.]+$/, '') === base;
  });
  return match?.[1].default;
}

// Stroke-icon path sets (24×24 viewBox) for the "Why Industry Specialism
// Matters" reasons, one per item in order.
const reasonIcons: string[] = [
  // Faster Onboarding (lightning / speed)
  '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  // Relevant KPIs (bar chart / metrics)
  '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  // Proactive Advice (radar / foresight)
  '<circle cx="12" cy="12" r="9"/><path d="M12 12 7 7"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>',
];

// Breadcrumb JSON-LD (CLAUDE.md §6). Origin mirrors BaseLayout's resolution.
const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: `${siteOrigin}/industries` },
  ],
};
---

<BaseLayout title={ind.seo.title} description={ind.seo.description}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />

  <PageHero
    eyebrow={hero.eyebrow}
    heading={hero.heading}
    subheading={hero.subheading}
    breadcrumbLabel="Industries"
    headingId="industries-hero-heading"
  >
    <Button href={hero.primaryCta.href} variant="primary" size="lg">
      {hero.primaryCta.label}
    </Button>
  </PageHero>

  {/* Sector grid — 1/2/3 columns. The 5th card naturally trails the second
      row, which reads cleanly on the engineered grid. */}
  <Section variant="surface" ariaLabel="Industries we specialise in">
    <div class="grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        industries.map((industry, i) => (
          <IndustryCard
            industry={industry}
            image={resolveImage(industry.image)}
            index={i}
          />
        ))
      }
    </div>
  </Section>

  {/* Why industry specialism matters — centered header + three reason cards. */}
  <Section variant="surface-2" ariaLabelledby="why-industries-title">
    <header class="mx-auto max-w-2xl text-center">
      <h2 id="why-industries-title" class="text-h2 font-bold">{why.heading}</h2>
      <p class="mt-5 text-lead text-muted">{why.subheading}</p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        why.reasons.map((reason, i) => (
          <article class="flex h-full flex-col rounded-xl border border-border bg-surface p-8 shadow-soft">
            <span
              class="flex h-14 w-14 items-center justify-center rounded-xl bg-brand-orange-soft text-brand-orange"
              aria-hidden="true"
            >
              <svg
                class="h-7 w-7"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={reasonIcons[i % reasonIcons.length]}
              />
            </span>
            <h3 class="mt-6 text-h4 font-semibold text-ink">{reason.title}</h3>
            <p class="mt-2 text-muted">{reason.description}</p>
          </article>
        ))
      }
    </div>
  </Section>

  {/* Fallback CTA — "Don't see your industry?" */}
  <CtaBand content={fallbackCta} id="industries-cta" />
</BaseLayout>
