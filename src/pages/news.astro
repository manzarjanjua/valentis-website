---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/primitives/Section.astro';
import Button from '../components/primitives/Button.astro';

/**
 * /news — "News & Insights". The article feed isn't built yet, so the page is
 * intentionally just the hero plus a single "coming soon" card. The header
 * "Resources" nav item points here too.
 */
const seo = {
  title: 'News & Insights | Valentis',
  description:
    'Stay informed with the latest tax updates, regulatory changes, and business insights that matter to UK directors and business owners.',
};

const hero = {
  eyebrow: 'NEWS & INSIGHTS',
  heading: 'News & Insights',
  subheading:
    'Stay informed with the latest tax updates, regulatory changes, and business insights that matter to UK directors and business owners.',
  primaryCta: { label: 'Book a Discovery Call', href: '#contact' },
};

const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'News', item: `${siteOrigin}/news` },
  ],
};
---

<BaseLayout title={seo.title} description={seo.description}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />

  <PageHero
    eyebrow={hero.eyebrow}
    heading={hero.heading}
    subheading={hero.subheading}
    breadcrumbLabel="News"
    headingId="news-hero-heading"
  >
    <Button href={hero.primaryCta.href} variant="primary" size="lg">
      {hero.primaryCta.label}
    </Button>
  </PageHero>

  {/* Coming-soon card — stands in for the article feed for now. */}
  <Section variant="surface" id="latest-updates" ariaLabelledby="latest-title">
    <div class="relative overflow-hidden rounded-3xl border border-border bg-surface-2 px-6 py-16 text-center md:px-12 md:py-24">
      <div
        class="pointer-events-none absolute -right-16 -top-20 h-64 w-64 rounded-full bg-brand-orange/10 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-2xl">
        <div class="flex justify-center">
          <span
            class="flex h-16 w-16 items-center justify-center rounded-2xl bg-brand-orange-soft text-brand-orange"
            aria-hidden="true"
          >
            <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Z" />
              <path d="M19 8h1a1 1 0 0 1 1 1v8a2 2 0 0 1-2 2" />
              <path d="M8 7h7M8 11h7M8 15h4" />
            </svg>
          </span>
        </div>

        <div class="mt-6 flex justify-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-brand-orange/30 bg-surface px-3.5 py-1.5 font-heading text-eyebrow font-semibold uppercase tracking-[0.14em] text-brand-orange">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-orange"></span>
            Coming soon
          </span>
        </div>

        <h2 id="latest-title" class="mt-6 text-h2 font-bold text-ink">Latest Updates</h2>
        <p class="mx-auto mt-5 max-w-xl text-lead text-muted">
          We're preparing tax updates, regulatory changes, and business insights to help UK
          directors and business owners stay ahead. Articles will appear here soon.
        </p>
      </div>
    </div>
  </Section>
</BaseLayout>
