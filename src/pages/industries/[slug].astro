---
import type { GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/primitives/Section.astro';
import Button from '../../components/primitives/Button.astro';
import IndustryBlock from '../../components/industries/IndustryBlock.astro';
import { industryDetails } from '../../lib/industryDetailsContent';
import type { IndustryDetail } from '../../lib/types';

export const getStaticPaths = (() => {
  return industryDetails.map((detail) => ({
    params: { slug: detail.slug },
    props: { detail },
  }));
}) satisfies GetStaticPaths;

interface Props {
  detail: IndustryDetail;
}

const { detail } = Astro.props;
const { hero, blocks } = detail;

const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';

// Breadcrumb JSON-LD: Home / Industries / <sector> (CLAUDE.md §6).
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: `${siteOrigin}/industries` },
    {
      '@type': 'ListItem',
      position: 3,
      name: detail.name,
      item: `${siteOrigin}/industries/${detail.slug}`,
    },
  ],
};

// FAQPage JSON-LD, built from any FAQ block on the page (CLAUDE.md §6 — only
// when genuine FAQ content exists; no invented content).
const faqBlock = blocks.find((b) => b.type === 'faq');
const faqLd =
  faqBlock && faqBlock.type === 'faq'
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqBlock.items.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null;

// Hero share image: the sector photo from src/assets/industries.
const heroImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/industries/*.{png,jpg,jpeg,webp,avif,svg}',
  { eager: true }
);
const heroImageEntry = Object.entries(heroImages).find(([path]) => {
  const file = path.split('/').pop() ?? '';
  return file.replace(/\.[^.]+$/, '') === detail.image;
});
const ogImage = heroImageEntry?.[1].default.src;
---

<BaseLayout title={detail.seo.title} description={detail.seo.description} ogImage={ogImage}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />
  {
    faqLd && (
      <script
        slot="head"
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(faqLd)}
      />
    )
  }

  <PageHero
    eyebrow={hero.eyebrow}
    heading={hero.heading}
    subheading={hero.subheading}
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Industries', href: '/industries' },
      { label: detail.name },
    ]}
    headingId="industry-hero-heading"
  >
    <Button href={hero.primaryCta.href} variant="primary" size="lg">
      {hero.primaryCta.label}
    </Button>
    {
      hero.secondaryCta && (
        <Button href={hero.secondaryCta.href} variant="secondary" size="lg" onDark>
          {hero.secondaryCta.label}
        </Button>
      )
    }
  </PageHero>

  {/* Intro lead — extra paragraph(s) and the positioning tagline. */}
  {
    (hero.lead?.length || hero.tagline) && (
      <Section variant="surface" space="sm" ariaLabel="Introduction">
        <div class="mx-auto max-w-3xl">
          {hero.lead?.map((para) => (
            <p class="text-lead text-muted [&:not(:first-child)]:mt-4">{para}</p>
          ))}
          {hero.tagline && (
            <p class="mt-6 border-l-2 border-brand-orange pl-5 text-h4 font-semibold text-ink">
              {hero.tagline}
            </p>
          )}
        </div>
      </Section>
    )
  }

  {blocks.map((block, i) => <IndustryBlock block={block} index={i} />)}
</BaseLayout>
