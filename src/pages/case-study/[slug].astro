---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/primitives/Section.astro';
import Eyebrow from '../../components/primitives/Eyebrow.astro';
import Button from '../../components/primitives/Button.astro';
import CtaBand from '../../components/home/CtaBand.astro';
import { caseStudies } from '../../lib/caseStudiesContent';
import type { CaseStudy } from '../../lib/types';

export function getStaticPaths() {
  return caseStudies.map((cs) => ({ params: { slug: cs.slug }, props: { cs } }));
}

interface Props {
  cs: CaseStudy;
}

const { cs } = Astro.props;

// Build-time optimized client logos (shared with the Stories grid).
const logos = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/stories/*.{png,jpg,jpeg,webp,svg}',
  { eager: true }
);
function resolveLogo(base: string): ImageMetadata | undefined {
  const match = Object.entries(logos).find(([path]) => {
    const file = path.split('/').pop() ?? '';
    return file.replace(/\.[^.]+$/, '') === base;
  });
  return match?.[1].default;
}
const logo = resolveLogo(cs.logo);

const siteOrigin = Astro.site?.origin ?? 'https://valentis.co.uk';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Stories', item: `${siteOrigin}/stories` },
    {
      '@type': 'ListItem',
      position: 3,
      name: cs.company,
      item: `${siteOrigin}/case-study/${cs.slug}`,
    },
  ],
};

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Stories', href: '/stories' },
  { label: cs.company },
];

const finalCta = {
  heading: 'Ready to write your success story?',
  body: 'Join businesses across the UK that have transformed their financial clarity with Valentis.',
  cta: { label: 'Book a Discovery Call', href: '#contact' },
};

const initials = (name: string) =>
  name
    .split(/\s+/)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? '')
    .join('');
---

<BaseLayout title={cs.seoTitle} description={cs.seoDescription}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />

  <PageHero
    eyebrow="Client Story"
    heading={cs.title}
    subheading={`${cs.company} · ${cs.trade}`}
    crumbs={crumbs}
    headingId="cs-hero-heading"
  >
    <Button href="#contact" variant="primary" size="lg">Book a Discovery Call</Button>

    <div
      slot="aside"
      class="mx-auto flex aspect-[3/2] w-full max-w-xs items-center justify-center rounded-2xl border border-white/10 bg-white p-8 shadow-lift"
    >
      {
        logo ? (
          <Image
            src={logo}
            alt={`${cs.logoAlt} logo`}
            widths={[280, 400]}
            sizes="20rem"
            loading="eager"
            decoding="async"
            class="max-h-full max-w-full object-contain"
          />
        ) : (
          <span class="font-heading text-h3 font-bold text-ink/30">{cs.logoAlt}</span>
        )
      }
    </div>
  </PageHero>

  {/* Body: interview (left) + client/metrics sidebar (right) */}
  <Section variant="surface">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      {/* Interview */}
      <article class="lg:col-span-8">
        <a
          href="/stories"
          class="inline-flex items-center gap-2 font-heading text-small font-semibold text-brand-orange"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
          </svg>
          All stories
        </a>

        <div class="mt-10 divide-y divide-border">
          {
            cs.sections.map((sec, i) => (
              <section class="py-9 first:pt-0 last:pb-0">
                <div class="flex items-baseline gap-4">
                  <span
                    class="font-heading text-h4 font-bold leading-none tabular-nums text-brand-orange/70"
                    aria-hidden="true"
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <h2 class="text-h3 font-semibold text-ink">{sec.heading}</h2>
                </div>
                <div class="mt-5 space-y-4 leading-relaxed text-ink/80 sm:ml-[2.75rem]">
                  {sec.paragraphs.map((p) => (
                    <p>{p}</p>
                  ))}
                </div>
              </section>
            ))
          }
        </div>
      </article>

      {/* Sidebar */}
      <aside class="lg:col-span-4">
        <div class="flex flex-col gap-6 lg:sticky lg:top-24">
          {/* Client */}
          <div class="rounded-2xl border border-border bg-surface-2 p-7">
            <p class="font-heading text-eyebrow font-semibold uppercase tracking-[0.14em] text-brand-orange">
              The client
            </p>
            <p class="mt-3 font-heading text-h4 font-semibold text-ink">{cs.company}</p>
            <p class="mt-1 text-small text-muted">{cs.trade}</p>
            <div class="mt-5 border-t border-border pt-5">
              <p class="font-medium text-ink">{cs.testimonial.name}</p>
              <p class="mt-0.5 text-small text-muted">{cs.testimonial.role}</p>
            </div>
            {
              cs.links && cs.links.length > 0 && (
                <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 border-t border-border pt-5">
                  {cs.links.map((l) => (
                    <li>
                      <a
                        href={l.href}
                        rel="noopener noreferrer"
                        target="_blank"
                        class="inline-flex items-center gap-1.5 text-small font-medium text-brand-orange transition-colors hover:text-ink"
                      >
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                          <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                        </svg>
                        {l.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )
            }
          </div>

          {/* Metrics */}
          {
            cs.metrics && cs.metrics.length > 0 && (
              <div class="rounded-2xl border border-border bg-surface p-7 shadow-soft">
                <p class="font-heading text-eyebrow font-semibold uppercase tracking-[0.14em] text-brand-orange">
                  At a glance
                </p>
                <dl class="mt-5 grid gap-4">
                  {cs.metrics.map((m) => (
                    <div class="rounded-xl border border-brand-orange/15 bg-brand-orange-soft px-5 py-5">
                      <dd class="font-heading text-h2 font-bold leading-none text-brand-orange">
                        {m.value}
                      </dd>
                      <dt class="mt-2.5 text-small font-medium text-ink">{m.label}</dt>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }

          {/* CTA */}
          <div class="rounded-2xl bg-ink-2 p-7 text-white">
            <p class="font-heading text-h4 font-semibold text-white">Work with Valentis</p>
            <p class="mt-2 text-small text-white/70">
              CFO-level thinking without CFO-level cost.
            </p>
            <Button href="#contact" variant="primary" class="mt-5 w-full">
              Book a Discovery Call
            </Button>
          </div>
        </div>
      </aside>
    </div>
  </Section>

  {/* Highlighted testimonial — light section + distinct quote card so it never
      merges with the dark final CTA below. */}
  <Section variant="surface-2" ariaLabelledby="cs-quote-title">
    <div class="mx-auto max-w-4xl">
      <Eyebrow>Client Success Story</Eyebrow>

      <figure class="mt-6 overflow-hidden rounded-2xl border border-border bg-surface p-8 shadow-card md:p-12">
        <svg
          class="h-12 w-12 text-brand-orange/30"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M9.5 7H6a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v1.5A1.5 1.5 0 0 1 6.5 18H6v2h.5A3.5 3.5 0 0 0 10 16.5V9a2 2 0 0 0-.5-2Zm10 0H16a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v1.5a1.5 1.5 0 0 1-1.5 1.5H16v2h.5a3.5 3.5 0 0 0 3.5-3.5V9a2 2 0 0 0-.5-2Z" />
        </svg>

        <blockquote
          id="cs-quote-title"
          class="mt-5 text-[1.375rem] font-medium leading-[1.5] text-ink md:text-[1.625rem]"
        >
          {cs.testimonial.quote}
        </blockquote>

        <figcaption class="mt-9 flex items-center gap-4 border-t border-border pt-7">
          <span
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-orange font-heading text-base font-semibold text-white"
            aria-hidden="true"
          >
            {initials(cs.testimonial.name)}
          </span>
          <span class="min-w-0">
            <span class="block font-heading font-semibold text-ink">{cs.testimonial.name}</span>
            <span class="block text-small text-muted">{cs.testimonial.role}</span>
          </span>
        </figcaption>
      </figure>
    </div>
  </Section>

  <CtaBand content={finalCta} id="cs-cta" />
</BaseLayout>
